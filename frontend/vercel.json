{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": false,
  "rewrites": [
    {
      "source": "/build-info.json",
      "destination": "https://travel-assistant-api-parity-preview.vercel.app/api/build-info"
    },
    {
      "source": "/api/:path*",
      "destination": "https://travel-assistant-api-parity-preview.vercel.app/api/:path*"
    }
  ]
}
