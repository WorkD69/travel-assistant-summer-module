# Copy to .env and fill secret values locally. Never commit .env.
DATABASE_URL="file:./dev.db"
JWT_SECRET=""

NODE_ENV="development"
PORT="3000"
FRONTEND_ORIGIN="http://localhost:8011"
PUBLIC_BASE_URL="http://localhost:3000"
FRONTEND_DIR=""

# OpenAI-compatible AI provider. B2 staging uses Groq.
AI_BASE_URL="https://api.groq.com/openai/v1"
AI_API_KEY=""
AI_MODEL="llama-3.3-70b-versatile"

# Telegram service-to-service integration.
BOT_SERVICE_TOKEN=""
TELEGRAM_BOT_USERNAME="your_test_bot"
BOT_LINK_TOKEN_TTL_MINUTES="10"
BOT_FILE_LINK_TTL_MINUTES="10"

OCR_TIMEOUT_MS="45000"
OPEN_METEO_DISABLED="false"
