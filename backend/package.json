{
  "name": "travel-assistant-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend for Travel Assistant - REST API + AI risk-monitoring assistant",
  "type": "commonjs",
  "scripts": {
    "test": "node --test \"test/*.test.js\"",
    "test:http": "node scripts/http-harness.js",
    "dev": "node src/server.js",
    "start": "prisma db push --skip-generate && node src/server.js",
    "seed": "node prisma/seed.js",
    "db:push": "prisma db push",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "@napi-rs/canvas": "^0.1.65",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^3.11.174",
    "tesseract.js": "^5.1.0"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  }
}
