BOT_ENV=development
BOT_DATA_MODE=mock
BOT_UPDATE_MODE=polling

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

TRAVEL_API_BASE_URL=http://localhost:8000
TRAVEL_API_SERVICE_TOKEN=
TRAVEL_API_TIMEOUT_SECONDS=15

WEB_APP_BASE_URL=http://localhost:8011

GEMINI_ENABLED=false
GEMINI_API_KEY=
GEMINI_MODEL=
AI_PROVIDER=mock
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_PROXY_URL=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=openai/gpt-oss-20b
AI_FALLBACK_TO_MOCK=true
AI_TIMEOUT_SECONDS=20
AI_MAX_RETRIES=1
AI_MAX_HISTORY_MESSAGES=8
AI_MAX_CONTEXT_CHARACTERS=16000
AI_MAX_OUTPUT_TOKENS=700

NOTIFICATION_MODE=polling
NOTIFICATION_POLL_INTERVAL_SECONDS=10

DATABASE_URL=sqlite+aiosqlite:///./bot_state.db
LOG_LEVEL=INFO
